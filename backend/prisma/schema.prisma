generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int       @id @default(autoincrement())
  username      String    @unique @db.VarChar(50)
  email         String    @unique @db.VarChar(100)
  password      String    @db.VarChar(255)
  phone         String?   @db.VarChar(20)
  avatar        String?   @db.VarChar(500)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  
  profile       Profile?
  education     Education[]
  workExperience WorkExperience[]
  projects      Project[]
  skills        Skill[]
  resumes       Resume[]
  jobDescriptions JobDescription[]
  atsReport     AtsReport[]
  interviewRecords InterviewRecord[]
  careerDocuments CareerDocument[]
  searchHistory   SearchHistory[]

  @@map("users")
}

model Profile {
  id              Int     @id @default(autoincrement())
  userId          Int     @unique @map("user_id")
  fullName        String  @db.VarChar(100)
  phone           String? @db.VarChar(20)
  email           String? @db.VarChar(100)
  website         String? @db.VarChar(200)
  address         String? @db.VarChar(200)
  city            String? @db.VarChar(50)
  jobTitle        String? @map("job_title") @db.VarChar(100)
  jobIntention    String? @map("job_intention") @db.VarChar(100)
  expectedSalary  String? @map("expected_salary") @db.VarChar(50)
  summary         String? @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user            User    @relation(fields: [userId], references: [id])

  @@map("profiles")
}

model Education {
  id          Int     @id @default(autoincrement())
  userId      Int     @map("user_id")
  school      String  @db.VarChar(100)
  major       String  @db.VarChar(100)
  degree      String  @db.VarChar(20)
  startDate   String  @map("start_date") @db.VarChar(20)
  endDate     String? @map("end_date") @db.VarChar(20)
  gpa         String? @db.VarChar(10)
  honors      String? @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User    @relation(fields: [userId], references: [id])

  @@map("education")
}

model WorkExperience {
  id            Int     @id @default(autoincrement())
  userId        Int     @map("user_id")
  company       String  @db.VarChar(100)
  industry      String? @db.VarChar(50)
  position      String  @db.VarChar(100)
  startDate     String  @map("start_date") @db.VarChar(20)
  endDate       String? @map("end_date") @db.VarChar(20)
  responsibilities String? @db.Text
  achievements  String? @db.Text
  teamSize      Int?    @map("team_size")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user          User    @relation(fields: [userId], references: [id])

  @@map("work_experience")
}

model Project {
  id            Int     @id @default(autoincrement())
  userId        Int     @map("user_id")
  name          String  @db.VarChar(100)
  startDate     String? @map("start_date") @db.VarChar(20)
  endDate       String? @map("end_date") @db.VarChar(20)
  techStack     String? @map("tech_stack") @db.VarChar(500)
  background    String? @db.Text
  responsibilities String? @db.Text
  contributions String? @db.Text
  results       String? @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user          User    @relation(fields: [userId], references: [id])

  @@map("projects")
}

model Skill {
  id          Int     @id @default(autoincrement())
  userId      Int     @map("user_id")
  category    String  @db.VarChar(50)
  name        String  @db.VarChar(100)
  level       String? @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at")

  user        User    @relation(fields: [userId], references: [id])

  @@map("skills")
}

model Resume {
  id          Int     @id @default(autoincrement())
  userId      Int     @map("user_id")
  title       String  @db.VarChar(100)
  template    String  @default("default") @db.VarChar(50)
  language    String  @default("zh") @db.VarChar(10)
  content     Json?
  pdfUrl      String? @map("pdf_url") @db.VarChar(500)
  isActive    Boolean @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User    @relation(fields: [userId], references: [id])
  versions    ResumeVersion[]

  @@map("resumes")
}

model ResumeVersion {
  id          Int     @id @default(autoincrement())
  resumeId    Int     @map("resume_id")
  version     Int     @default(1)
  content     Json?
  changeNotes String? @map("change_notes") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  resume      Resume  @relation(fields: [resumeId], references: [id])

  @@map("resume_versions")
}

model JobDescription {
  id          Int     @id @default(autoincrement())
  userId      Int     @map("user_id")
  title       String  @db.VarChar(200)
  company     String? @db.VarChar(100)
  rawContent  String  @map("raw_content") @db.Text
  parsedData  Json?   @map("parsed_data")
  matchScore  Int?    @map("match_score")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User    @relation(fields: [userId], references: [id])
  atsReports  AtsReport[]

  @@map("job_descriptions")
}

model AtsReport {
  id                Int     @id @default(autoincrement())
  userId            Int     @map("user_id")
  resumeId          Int?
  jobDescriptionId  Int?    @map("job_description_id")
  overallScore      Int     @map("overall_score")
  keywordScore      Int?    @map("keyword_score")
  skillMatchScore   Int?    @map("skill_match_score")
  projectScore      Int?    @map("project_score")
  achievementScore  Int?    @map("achievement_score")
  formatScore       Int?    @map("format_score")
  details           Json?
  suggestions       Json?
  createdAt         DateTime @default(now()) @map("created_at")

  user              User    @relation(fields: [userId], references: [id])
  jobDescription    JobDescription? @relation(fields: [jobDescriptionId], references: [id])

  @@map("ats_reports")
}

model InterviewRecord {
  id          Int     @id @default(autoincrement())
  userId      Int     @map("user_id")
  jobId       Int?
  type        String  @db.VarChar(50)
  questions   Json?
  answers     Json?
  feedback    Json?
  score       Int?
  createdAt   DateTime @default(now()) @map("created_at")

  user        User    @relation(fields: [userId], references: [id])

  @@map("interview_records")
}

model CareerDocument {
  id          Int     @id @default(autoincrement())
  userId      Int     @map("user_id")
  title       String  @db.VarChar(200)
  type        String  @db.VarChar(50)
  content     String? @db.Text
  fileUrl     String? @map("file_url") @db.VarChar(500)
  vectorId    String? @map("vector_id") @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User    @relation(fields: [userId], references: [id])

  @@map("career_documents")
}

model SearchHistory {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  type        String   @db.VarChar(50)
  query       String   @db.VarChar(500)
  results     Json?
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@map("search_history")
}
