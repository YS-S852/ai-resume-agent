# ─── Database ───
# Replace with your real MySQL connection. NEVER commit real credentials.
DATABASE_URL="mysql://root:YOUR_PASSWORD@localhost:3306/resume_pilot_ai?charset=utf8mb4"

# ─── Auth ───
# Change this to a long random string in production (e.g. `openssl rand -hex 32`)
JWT_SECRET="change-me-to-a-random-secret"
PORT=3002

# ─── DeepSeek AI ───
# Get your API key at https://platform.deepseek.com
# Recommended model names (legacy deepseek-chat / deepseek-reasoner will be
# retired on 2026-07-24 — use the v4 names below):
#   deepseek-v4-pro    (reasoning / thinking mode)
#   deepseek-v4-flash  (fast / non-thinking mode)
DEEPSEEK_API_KEY="sk-your-deepseek-api-key-here"
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL_PRO="deepseek-v4-pro"
DEEPSEEK_MODEL_FLASH="deepseek-v4-flash"

# ─── Qdrant Vector Database ───
QDRANT_URL="http://localhost:6333"
